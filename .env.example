# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Session signing — generate a long random string
SESSION_SECRET=

# Anthropic SDK (used by Learn Mode grading, flashcard elaboration,
# NREMT quiz validation, and Drill Mode grading)
ANTHROPIC_API_KEY=

# Drill Mode — third-party services
# DEEPGRAM_API_KEY is server-side only. The browser never sees it.
# The server mints short-lived tokens or proxies the streaming connection.
DEEPGRAM_API_KEY=

# Drill Mode feature flag. Set to "true" to expose /drill/scenario-1a
# and show the entry point on the Scenario 1A landing.
DRILL_MODE_ENABLED=false

# Server
NODE_ENV=development
PORT=5050

# Note: R2 / ElevenLabs / Stripe vars are intentionally omitted from this
# Phase 1 .env.example — real asset generation and payment integration
# are out of scope for the initial Drill Mode build.
